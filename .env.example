APP_NAME=Indoor Visual-Spatial Description
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
TLS_CERTFILE=./certs/localhost.pem
TLS_KEYFILE=./certs/localhost-key.pem
HOST=127.0.0.1
PORT=8000

LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=google/gemma-4-e2b
LM_STUDIO_TIMEOUT=240
LM_STUDIO_HEALTH_TIMEOUT=2
LM_STUDIO_MAX_TOKENS=900
GEMMA_MOCK=false

ANALYSIS_QUEUE_CAPACITY=8
ANALYSIS_RETAINED_JOBS=100

SENSOR_SERIAL_PORT=
SENSOR_SERIAL_BAUD=115200
SENSOR_MATCH_WINDOW_MS=250
SENSOR_MAX_CLOCK_SKEW_MS=5000
SENSOR_RECONNECT_INTERVAL_MS=1000
SENSOR_STATUS_WINDOW_MS=1000
SENSOR_FRESHNESS_MAX_AGE_MS=1000
SENSOR_PAIR_DISAGREEMENT_CM=15
SENSOR_CLOCK_RTT_MAX_MS=1000
CAMERA_SENSOR_OFFSET_CM=3.0
SENSOR_CALIBRATION_PATH=./config/sensor_camera_calibration.json
SENSOR_CALIBRATION_MEASUREMENTS_PATH=./config/sensor_camera_calibration_measurements.json
SENSOR_VERIFICATION_PATH=./config/sensor_camera_verification.json
SENSOR_VERIFICATION_MEASUREMENTS_PATH=./config/sensor_camera_verification_measurements.json

MAX_IMAGE_SIZE_MB=5
IMAGE_MAX_DIMENSION=768
SAVE_RESULTS=true
RESULTS_DIR=./results
