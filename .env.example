APP_NAME=Depth-Aware Image Description
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
HOST=127.0.0.1
PORT=8000

LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=gemma-4-e4b-it
LM_STUDIO_TIMEOUT=60
LM_STUDIO_HEALTH_TIMEOUT=2
GEMMA_MOCK=false

ENABLE_DEPTH_ESTIMATION=true
DEPTH_MODEL_PATH=./model_weights/Depth-Anything-V2-Metric-Indoor-Small-hf
DEPTH_INPUT_SIZE=518
DEPTH_MOCK=false

MAX_IMAGE_SIZE_MB=5
IMAGE_MAX_DIMENSION=768
SAVE_RESULTS=true
SAVE_DEPTH_MAP=true
RESULTS_DIR=./results
